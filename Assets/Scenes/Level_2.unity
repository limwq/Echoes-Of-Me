    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[1]
      value: "The attack\u2026 it disrupted everything. Time itself is starting to
        fracture"
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[2]
      value: "Every second I delay, the distortion grows stronger. I can\u2019t afford
        to fail"
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[3]
      value: "This mask\u2026 it carries unimaginable power, but without control,
        it will consume us all"
