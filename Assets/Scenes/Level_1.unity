--- !u!1001 &1532742276
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    m_TransformParent: {fileID: 179785912}
    m_Modifications:
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: spriteToRender
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: durationPerSentence
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[0]
      value: "\u201CThese halls\u2026 they feel strangely familiar. Have I been here
        before?\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[1]
      value: "Still\u2026 if I can control it, maybe it will help me escape"
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[2]
      value: "But now\u2026 this place feels different. Broken. Dangerous"
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[3]
      value: "The mask is still in my hand\u2026 it dragged me here"
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: sentences.Array.data[4]
      value: "I don\u2019t understand\u2026 but if I stay, I\u2019ll be buried alive.
        I need to escape"
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596883, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: m_Name
      value: SubtitleTrigger (2)
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596892, guid: 67d26f8b6d9773a42a128d678d57c198, type: 3}
      propertyPath: m_RootOrder
      value: 2
      objectReference: {fileID: 0}
